#=====================================================================#
#           LibreChat — bearclaw family deploy                        #
#=====================================================================#
# Copy this to .env and fill in real values.
# NEVER commit the real .env — it is in .gitignore.

#==============#
# App / Server #
#==============#
HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=http://bearclaw:3080
DOMAIN_SERVER=http://bearclaw:3080
TRUST_PROXY=1

UID=1000
GID=1000

#==============#
# Mongo        #
#==============#
MONGO_URI=mongodb://mongodb:27017/LibreChat

#==============#
# Meilisearch  #
#==============#
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=<generate: openssl rand -hex 32>

#==============#
# Anthropic    #
#==============#
ANTHROPIC_API_KEY=<your-anthropic-api-key>
# Sonnet only for default endpoint — Opus available via Claude-Admin custom endpoint in librechat.yaml
ANTHROPIC_MODELS=claude-sonnet-4-6

#================================#
# Disable all other providers    #
#================================#
OPENAI_API_KEY=
GOOGLE_KEY=
ASSISTANTS_API_KEY=
BINGAI_TOKEN=

# Only expose anthropic + custom — disables Agents endpoint (v0.8.5+ default for new users;
# causes "agent_id required" error without a configured agent)
ENDPOINTS=anthropic,custom

#==============#
# Auth         #
#==============#
# Set to false after both accounts (matt + son) are created
ALLOW_REGISTRATION=true
ALLOW_EMAIL_LOGIN=true
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false

#==============#
# Email (off)  #
#==============#
EMAIL_FROM=
EMAIL_SERVICE=

#==============#
# Rate limits  #
#==============#
LIMIT_MESSAGE_IP=false
LIMIT_MESSAGE_USER=true
MESSAGE_USER_MAX=50
MESSAGE_USER_WINDOW=60

#==========================#
# Title model (cheap)      #
#==========================#
OPENAI_TITLE_MODEL=claude-haiku-4-5-20251001

#==============#
# Secrets      #
#==============#
CREDS_KEY=<generate: openssl rand -hex 32>
CREDS_IV=<generate: openssl rand -hex 16>
JWT_SECRET=<generate: openssl rand -hex 32>
JWT_REFRESH_SECRET=<generate: openssl rand -hex 32>

DEBUG_LOGGING=true
DEBUG_CONSOLE=false
CONSOLE_JSON=false
NO_INDEX=true
